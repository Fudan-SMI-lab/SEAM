{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Experience Refinement Output",
  "type": "object",
  "required": ["type", "title"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["skill", "document", "rule", "prompt"]
    },
    "skill_name": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "subtype": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "root_cause": {
      "type": "string"
    },
    "fix_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affected_patterns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "code_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string"
          },
          "before": {
            "type": "string"
          },
          "after": {
            "type": "string"
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "meta": {
      "type": "object"
    }
  }
}
