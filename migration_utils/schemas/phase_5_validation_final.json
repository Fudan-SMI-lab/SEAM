{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 5: Final Validation Output",
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean"
    },
    "iteration_count": {
      "type": "integer"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "category": {
            "type": "string"
          }
        },
        "required": ["message", "category"]
      }
    }
  },
  "required": ["success", "iteration_count", "errors"]
}
