{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 0: Environment Detection Output",
  "description": "The detection field present varies by platform — only the field matching the detected platform is expected.",
  "type": "object",
  "properties": {
    "platform": {
      "type": "string",
      "enum": ["npu", "cuda", "ppu", "musa", "rocm", "mlu"]
    },
    "npu_detected": {
      "type": "boolean"
    },
    "ppu_detected": {
      "type": "boolean"
    },
    "musa_detected": {
      "type": "boolean"
    },
    "rocm_detected": {
      "type": "boolean"
    },
    "mlu_detected": {
      "type": "boolean"
    },
    "cuda_detected": {
      "type": "boolean"
    },
    "python_version": {
      "type": "string"
    }
  },
  "required": ["platform", "python_version"]
}
