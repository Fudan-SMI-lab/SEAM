{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 1: Project Analysis Output",
  "type": "object",
  "properties": {
    "project_dir": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cuda_detected": {
      "type": "boolean"
    },
    "entry_script": {
      "type": "string"
    },
    "custom_op_surface": {
      "type": "object",
      "properties": {
        "custom_op_detected": {
          "type": "boolean"
        },
        "discovery_complete": {
          "type": "boolean"
        },
        "discovery_sources_checked": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "searched_source_roots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "searched_source_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operator_families": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fine_grained_operator_units": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "discovered_operator_names": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "native_operator_symbols": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kernel_launch_sites": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "negative_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dynamic_loading_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "build_load_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unresolved_source_groups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope_source_groups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fine_grained_operator_unit_evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "unit_identity": {
                "type": "string"
              },
              "source_evidence": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "candidate_public_api_routes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "candidate_framework_integration_routes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "unit_identity",
              "source_evidence"
            ],
            "additionalProperties": true
          }
        },
        "variant_axes_detected": {
          "type": "boolean"
        },
        "variant_axes": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": [
                "string",
                "number",
                "integer"
              ]
            }
          }
        },
        "expanded_operator_variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "unit_identity": {
                "type": "string"
              },
              "base_unit_identity": {
                "type": "string"
              },
              "source_unit_identity": {
                "type": "string"
              },
              "axis_values": {
                "type": "object"
              },
              "variant_axes": {
                "type": "object"
              },
              "source_evidence": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "candidate_public_api_routes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "candidate_framework_integration_routes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "unit_identity",
              "source_evidence"
            ],
            "additionalProperties": true
          }
        },
        "expanded_operator_instances_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "custom_op_detected",
        "discovery_complete",
        "discovery_sources_checked",
        "searched_source_roots",
        "searched_source_paths",
        "operator_families",
        "fine_grained_operator_units",
        "discovered_operator_names",
        "native_operator_symbols",
        "kernel_launch_sites",
        "source_evidence",
        "negative_evidence",
        "dynamic_loading_checks",
        "build_load_checks",
        "unresolved_source_groups",
        "out_of_scope_source_groups",
        "fine_grained_operator_unit_evidence"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "project_dir",
    "dependencies",
    "cuda_detected",
    "entry_script"
  ]
}
