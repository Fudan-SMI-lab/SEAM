#!/bin/bash
# nvcc → mxcc wrapper for MACA GPU
# Handles CMake detection flags and translates nvcc flags to mxcc equivalents.

MXCC=/opt/maca/mxgpu_llvm/bin/mxcc
MACA_PATH=/opt/maca
COMPAT_INC=/workspace/maca_cuda_compat/include

# Check if this is a CMake detection call (--version)
if [ "$1" = "--version" ]; then
    echo "nvcc: NVIDIA (R) Cuda compiler driver"
    echo "Copyright (c) 2005-2024 NVIDIA Corporation"
    echo "Built on Wed_Nov_20_12:00:00_PST_2024"
    echo "Cuda compilation tools, release 12.4, V12.4.131"
    echo "Build cuda_12.4.r12.4/compiler.34097967_0"
    exit 0
fi

# Check if this is a CMake determine_cuda call
for arg in "$@"; do
    if [ "$arg" = "__cmake_determine_cuda" ]; then
        echo "#\$ TOP=$MACA_PATH"
        echo "#\$ NVVMIR_LIBRARY_DIR=$MACA_PATH/nvvm/libdevice"
        echo "#\$ PATH=$MACA_PATH/bin"
        exit 0
    fi
done

# Build mxcc arguments
ARGS=()
SKIP_NEXT=false

for arg in "$@"; do
    if $SKIP_NEXT; then
        SKIP_NEXT=false
        continue
    fi

    case "$arg" in
        -DCMAKE_CUDA_*)
            ;;
        -arch=*)
            ARCH_VAL="${arg#-arch=}"
            ARGS+=("--offload-arch=sm_80")
            ;;
        -gencode=*|--generate-code=*|-gencode|--generate-code)
            if [ "$arg" = "-gencode" ] || [ "$arg" = "--generate-code" ]; then
                SKIP_NEXT=true
            fi
            ;;
        --use_fast_math)
            ARGS+=("-use-fast-math")
            ;;
        --restrict)
            ARGS+=("--restrict")
            ;;
        -O3|-O2|-O1|-O0|-g|--debug)
            ARGS+=("$arg")
            ;;
        -Xcompiler=*)
            ARGS+=("$arg")
            ;;
        -D*)
            ARGS+=("$arg")
            ;;
        -I*|-isystem*|-L*|-l*)
            ARGS+=("$arg")
            ;;
        -std=*)
            ARGS+=("$arg")
            ;;
        -c|-shared|-o)
            ARGS+=("$arg")
            ;;
        -fPIC|-fpic)
            ARGS+=("$arg")
            ;;
        -w|-v)
            ARGS+=("$arg")
            ;;
        --forward-unknown-to-host-compiler|--compiler-options*|--linker-options*)
            ;;
        --*)
            ;;
        -*=*)
            ;;
        *.cu|*.c|*.cpp|*.cxx|*.cc|*.o|*.a|*.so|*.obj)
            ARGS+=("$arg")
            ;;
        *)
            ARGS+=("$arg")
            ;;
    esac
done

exec $MXCC -D__CUDACC__ --maca-path="$MACA_PATH" -I"$COMPAT_INC" "${ARGS[@]}"
